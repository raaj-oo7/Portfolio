# ──────────────────────────────────────────────────────────────────────────
# CLIENT-SIDE variables (VITE_ prefix — these are PUBLIC, bundled into JS)
# Copy to .env.local for local development.
# ──────────────────────────────────────────────────────────────────────────

# GitHub username — powers the live Projects section and profile links
VITE_GITHUB_USERNAME=raaj-oo7

# Cloudflare Turnstile SITE key (public) — enables the spam-check widget on
# the contact form. Get keys at https://dash.cloudflare.com → Turnstile.
VITE_TURNSTILE_SITE_KEY=

# EmailJS — FALLBACK contact transport, used only when /api/contact is not
# deployed (e.g. static hosting without Vercel functions).
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# AI assistant — optional. Without a key, a built-in local knowledge engine
# answers. WARNING: any VITE_ key ships to the browser; prefer a proxy.
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-4o-mini

# ──────────────────────────────────────────────────────────────────────────
# SERVER-SIDE variables — power /api/contact (Resend + Turnstile verify).
# Production: set in the VERCEL DASHBOARD.
# Local dev:  put them in .env.local — the Vite dev server mounts the same
#             API handler, so the form REALLY sends email locally too.
# Never prefix these with VITE_ and never commit real values.
# (MY_EMAIL / FROM_EMAIL are accepted aliases for the CONTACT_* names.)
# ──────────────────────────────────────────────────────────────────────────

# RESEND_API_KEY=re_xxxxxxxxxxxx          # https://resend.com → API Keys
# CONTACT_TO_EMAIL=raj.makadia22@gmail.com # where inquiries arrive
# CONTACT_FROM_EMAIL="Raj Makadia <onboarding@resend.dev>"  # verified sender
# TURNSTILE_SECRET_KEY=0x_xxxxxxxxxxxx    # Turnstile SECRET key (optional)
